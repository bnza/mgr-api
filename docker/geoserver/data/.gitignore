# Ignore volatile runtime data
logs/*
!logs/*.xml
temp/
tmp/

# Ignore all subdirectories in GWC (this catches the tile folders)
gwc/tmp/

# Allow the config files
!gwc/*.xml

# Ignore security secrets (auto-generated by GeoServer on first startup)
security/masterpw/default/passwd
security/geoserver.jceks
security/masterpw.digest
security/usergroup/default/users.xml
